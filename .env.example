# Azure Blob Storage Configuration
# Your Azure storage container name
AZURE_STORAGE_CONTAINER_NAME=your_container_name_here

# Your Azure Shared Access Signature (SAS) key
# Example format: ?sv=2022-11-02&ss=b&srt=co&sp=rwdlacupiytfx&se=2025-12-31T00:00:00Z&st=2024-01-01T00:00:00Z&spr=https&sig=your_signature
AZURE_SAS_KEY=your_sas_token_here

# App Information
APP_NAME=CloudVault
